{
  "name": "ccr-calendar-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:single": "npm run build && node scripts/build-single-html.mjs",
    "electron:start": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist:win": "npm run build && electron-builder --win portable",
    "preview": "vite preview --host 127.0.0.1",
    "test": "tsc -p tsconfig.test.json && node --test .tmp/test-build/test/*.test.js",
    "verify:sequence": "node scripts/verify-sequence.mjs"
  },
  "build": {
    "appId": "com.ccr.calendar",
    "productName": "CCR 캘린더",
    "artifactName": "CCR-Calendar-Windows-Portable-${version}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "CCR-Calendar-Windows-Portable-${version}.exe"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.0"
  }
}
